                    for (var i = 0; i < data.length; i++) {
                        retVal += "\n\t\t\t<li><a href='./"+data[i] + "'>" + data[i] + "</a></li>";
                    }
                    retVal += "\n\t\t</ul>\n\t</body>\n</html>";
                    res.end(retVal);
                }
            }
        }
    }
  });
  server.listen(PORT);
}

function updatePort(nr){
    PORT=nr;
    server.close();
    server.listen(PORT);
}

function close(){
    server.close()
}
exports.start=start;
exports.rpcMethods=rpcMethods;
exports.updatePort=updatePort;
exports.port=function(){return PORT};
exports.close = close;