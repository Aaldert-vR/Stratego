const url = require('url');
const http = require('http');
const fs = require('fs');
const path=require('path');
let querystring=require('querystring');
let PORT = 8080;

function getFile(filename){
    let returnVal={status: 200};
    try{
        let fDat=fs.readFileSync(filename);
        returnVal.contents=fDat;
    }
    catch(err){
        returnVal.status=404;
    }
    return returnVal;
}

rpcMethods={}



function JSONrpc(JSONInput){
  let jsonObject=JSON.parse(JSONInput);
  let method=jsonObject.method;
  let params=jsonObject.params;
  if (!(method in rpcMethods)){
    return {methodExists: false, id: jsonObject.id}
  }
  let retVal={methodExists: true, result: rpcMethods[method](params)};
  retVal.id=jsonObject.id;
  return retVal;
}

async function start(port=PORT){
    PORT=port;
    server = http.createServer((req, res) => {
    res.setHeader("Access-Control-Allow-Origin", "*");
    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');
    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization');
    console.log(res.headers);
    let index=false;
    let referer="";
    let requestUrl=url.parse(req.url);
    
    if(req.headers.referer!=undefined){
        referer="."+url.parse(req.headers.referer).pathname;
    }
    if (requestUrl.href.includes(requestUrl.host)){
        requestUrl.href="./"+requestUrl.pathname
        
    }
    let requrl=path.join(referer, req.url);
    console.log(req.url);
    console.log(req.method);
    console.log(req._header);
    console.log(requrl);
    console.log(res);
    if (req.url=="/" || req.url==""){
        if (req.method=="POST"){
            res.status=200;
            let data='';
            req.on('data', chunk => {
                data+=chunk.toString();
            });
            req.on('end', () => {
                res.statusCode=200;
                console.log(data);
                let q=querystring.parse(data);
                var r=JSONrpc(q.JSON);
                if (!(r.methodExists)){
                    r.result="404 function not found";
                }
                delete r.methodExists;
                r.JSONrpc="2.0";
