                delete r.result;
                r.result=abc;
                abc=r.id;
                delete r.id;
                r.id=abc;
                console.log(r)
                res.end(JSON.stringify(r));
                console.log(res);
            })
            //res.end(JSON.stringify(data));
        }
        else{
            index=true;
        }
    }
    if((requrl!="./" && requrl!="") || index){
        let q=url.parse(requrl,true);
        //console.log(q);
        //console.log(__dirname);
        //console.log("host");
        ///console.log(req.host);
        //res.end(JSON.stringify(req));
        //let requrl=path.join(__dirname, q.pathname);
        //let requrl=q.pathname;
        const fName = path.basename(requrl);
        
        let fPath = path.relative(requrl,__dirname);
        if (fName.includes(".")) {
            const f = getFile(requrl);
            if (f.status == 404) {
                res.status=404;
                res.end();
            }
            else {
                res.status=200;
                res.end(f.contents);
